{
  "name": "food-crm-backend",
  "version": "0.1.0",
  "private": true,
  "type": "commonjs",
  "scripts": {
    "dev": "tsx watch --tsconfig tsconfig.json src/server.ts",
    "admin:create": "tsx --tsconfig tsconfig.json scripts/create-admin.ts",
    "workspace-accounts:create": "tsx --tsconfig tsconfig.json scripts/create-workspace-accounts.ts",
    "db:seed:dev": "tsx --tsconfig tsconfig.json scripts/seed-dev-data.ts",
    "local:time:set": "tsx --tsconfig tsconfig.json scripts/local-time.ts set",
    "local:time:reset": "tsx --tsconfig tsconfig.json scripts/local-time.ts reset",
    "local:time:show": "tsx --tsconfig tsconfig.json scripts/local-time.ts show",
    "profile:sales-analytics": "tsx --tsconfig tsconfig.json scripts/profile-sales-analytics.ts",
    "build": "tsc -p tsconfig.json --noEmit",
    "db:deploy": "prisma migrate deploy",
    "start": "tsx --tsconfig tsconfig.json src/server.ts",
    "test": "node --import tsx --test \"src/**/*.test.ts\"",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@fastify/cookie": "^11.0.2",
    "@fastify/cors": "^11.1.0",
    "@prisma/client": "^7.8.0",
    "@types/pg": "^8.20.0",
    "dotenv": "^17.4.2",
    "fastify": "^5.6.1",
    "pg": "^8.20.0",
    "sharp": "^0.34.5"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "prisma": "^7.8.0",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3"
  }
}
