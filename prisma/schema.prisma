generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum OrderStatus {
  SENT_TO_KITCHEN
  READY
  PACKED
  DELIVERED_PAID
  CANCELLED
}

enum ClientType {
  CLIENT
  ORGANIZATION
}

model User {
  id                Int      @id @default(autoincrement())
  phone             String   @unique
  password          String
  role              String   @default("admin")
  passwordUpdatedAt DateTime?
  createdAt         DateTime @default(now())
  sessions          Session[]
}

model Session {
  sessionId String    @id @default(uuid())
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId    Int
  createdAt DateTime  @default(now())
  expiresAt DateTime
  revokedAt DateTime?
  userAgent String?
  ip        String?

  @@index([userId])
  @@index([expiresAt])
  @@map("sessions")
}

model AuthAttempt {
  attemptKey      String    @id
  count           Int       @default(0)
  windowStartedAt DateTime  @default(now())
  lockedUntil     DateTime?
  updatedAt       DateTime  @updatedAt

  @@map("auth_attempts")
}

model AuditLog {
  id          Int      @id @default(autoincrement())
  actorUserId Int?
  action      String
  entityType  String
  entityId    String?
  before      Json?
  after       Json?
  createdAt   DateTime @default(now())
  ip          String?

  @@index([actorUserId])
  @@index([entityType, entityId])
  @@index([createdAt])
  @@map("audit_log")
}

model Client {
  id        Int      @id @default(autoincrement())
  name      String
  type      ClientType @default(CLIENT)
  email     String?
  phone     String   @unique
  birthDate DateTime?
  address   String?
  notes     String?
  loyaltyLevelOverride String?
  createdAt DateTime @default(now())
  orders    Order[]
}

model PhoneVerificationCode {
  id         Int       @id @default(autoincrement())
  phone      String
  purpose    String
  codeHash   String
  attempts   Int       @default(0)
  expiresAt  DateTime
  consumedAt DateTime?
  createdAt  DateTime  @default(now())

  @@index([phone, purpose, createdAt])
}

model Product {
  id          Int      @id @default(autoincrement())
  name        String
  sku         String?  @unique
  category    String?
  unit        String
  stockQuantity Float  @default(0)
  priceCents  Int
  description String?
  createdAt   DateTime @default(now())
  orderItems  OrderItem[]
  ingredients TechCardIngredient[]
  inventoryItems InventorySessionItem[]
  incomingItems IncomingActItem[]
  writeoffItems WriteoffActItem[]
  orderInventoryMovements OrderInventoryMovement[]
}

model Employee {
  id           Int      @id @default(autoincrement())
  name         String
  email        String?  @unique
  role         String
  phone        String?
  messenger    String?
  schedule     Json?    // График работы, например { "monday": 8, "tuesday": 8, ... }
  monthlyHours Int?     // Рассчитанные часы работы за месяц
  birthDate    DateTime?
  hireDate     DateTime?
  passwordUpdatedAt DateTime?
  createdAt    DateTime @default(now())
  orders       Order[]
  adjustments  EmployeeAdjustment[]
  inventorySessions InventorySession[]
  incomingActs IncomingAct[]
  writeoffActs WriteoffAct[]
}

enum EmployeeAdjustmentType {
  ADVANCE
  FINE
  DEBT
}

model EmployeeAdjustment {
  id         Int                     @id @default(autoincrement())
  employee   Employee                @relation(fields: [employeeId], references: [id])
  employeeId Int
  type       EmployeeAdjustmentType
  amountCents Int
  comment    String?
  createdAt  DateTime                @default(now())
}

model Order {
  id          Int         @id @default(autoincrement())
  status      OrderStatus @default(SENT_TO_KITCHEN)
  source      String      @default("ADMIN")
  isInternal  Boolean     @default(false)
  client      Client?     @relation(fields: [clientId], references: [id], onDelete: SetNull)
  clientId    Int?
  clientNameSnapshot String
  clientTypeSnapshot ClientType
  customerPhoneSnapshot String?
  deliveryAddressSnapshot String?
  customerComment String?
  employee    Employee    @relation(fields: [employeeId], references: [id])
  employeeId  Int
  subtotalCents Int
  discountPercent Int      @default(0)
  totalCents  Int
  createdAt   DateTime    @default(now())
  items       OrderItem[]
  inventoryMovements OrderInventoryMovement[]
}

model OrderInventoryMovement {
  id                  Int      @id @default(autoincrement())
  order               Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  orderId             Int
  product             Product  @relation(fields: [productId], references: [id])
  productId           Int
  productName         String
  productUnit         String
  quantity            Float
  movementType        String
  orderStatus         OrderStatus
  reason              String
  actorUserId         Int?
  stockQuantityBefore Float
  stockQuantityAfter  Float
  createdAt           DateTime @default(now())

  @@unique([orderId, productId, movementType])
  @@index([orderId, createdAt])
  @@index([productId, createdAt])
}

model OrderItem {
  id              Int     @id @default(autoincrement())
  order           Order   @relation(fields: [orderId], references: [id])
  orderId         Int
  product         Product? @relation(fields: [productId], references: [id])
  productId       Int?
  catalogItem     CatalogItem? @relation(fields: [catalogItemId], references: [id])
  catalogItemId   Int?
  itemName        String
  quantity        Int
  unitPriceCents  Int
  totalPriceCents Int
}

model TechnologicalCard {
  id             Int                  @id @default(autoincrement())
  name           String
  category       String
  pizzaSize      String?
  rollSize       String?
  outputQuantity Float
  outputUnit     String
  description    String?
  createdAt      DateTime             @default(now())
  ingredients    TechCardIngredient[]
  catalogItems   CatalogItem[]
}

model TechCardIngredient {
  id                  Int               @id @default(autoincrement())
  technologicalCard   TechnologicalCard @relation(fields: [technologicalCardId], references: [id])
  technologicalCardId Int
  product             Product           @relation(fields: [productId], references: [id])
  productId           Int
  quantity            Float
  unit                String
}

model CatalogItem {
  id                  Int               @id @default(autoincrement())
  name                String
  slug                String            @unique
  category            String?
  description         String?
  imageUrl            String?
  priceCents          Int
  isPublished         Boolean           @default(false)
  displayOrder        Int               @default(0)
  createdAt           DateTime          @default(now())
  technologicalCard   TechnologicalCard @relation(fields: [technologicalCardId], references: [id])
  technologicalCardId Int
  orderItems          OrderItem[]
}

model InventorySession {
  id                    Int                    @id @default(autoincrement())
  responsibleEmployee   Employee               @relation(fields: [responsibleEmployeeId], references: [id])
  responsibleEmployeeId Int
  notes                 String?
  createdAt             DateTime               @default(now())
  closedAt              DateTime?
  items                 InventorySessionItem[]
}

model InventorySessionItem {
  id                 Int              @id @default(autoincrement())
  inventorySession   InventorySession @relation(fields: [inventorySessionId], references: [id])
  inventorySessionId Int
  product            Product?         @relation(fields: [productId], references: [id], onDelete: SetNull)
  productId          Int?
  productName        String
  productCategory    String?
  productUnit        String
  stockQuantity      Float
  actualQuantity     Float?
}

model IncomingAct {
  id                    Int               @id @default(autoincrement())
  responsibleEmployee   Employee          @relation(fields: [responsibleEmployeeId], references: [id])
  responsibleEmployeeId Int
  supplierName          String?
  notes                 String?
  createdAt             DateTime          @default(now())
  completedAt           DateTime?
  items                 IncomingActItem[]
}

model IncomingActItem {
  id                  Int         @id @default(autoincrement())
  incomingAct         IncomingAct @relation(fields: [incomingActId], references: [id])
  incomingActId       Int
  product             Product     @relation(fields: [productId], references: [id])
  productId           Int
  productName         String
  productCategory     String?
  productUnit         String
  quantity            Float
  priceCents          Int
  stockQuantityBefore Float?
  stockQuantityAfter  Float?
}

model WriteoffAct {
  id                    Int               @id @default(autoincrement())
  responsibleEmployee   Employee          @relation(fields: [responsibleEmployeeId], references: [id])
  responsibleEmployeeId Int
  reason                String
  notes                 String?
  createdAt             DateTime          @default(now())
  completedAt           DateTime?
  items                 WriteoffActItem[]
}

model WriteoffActItem {
  id                  Int         @id @default(autoincrement())
  writeoffAct         WriteoffAct @relation(fields: [writeoffActId], references: [id])
  writeoffActId       Int
  product             Product     @relation(fields: [productId], references: [id])
  productId           Int
  productName         String
  productCategory     String?
  productUnit         String
  quantity            Float
  priceCents          Int
  stockQuantityBefore Float?
  stockQuantityAfter  Float?
}
