generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum OrderStatus {
  NEW
  SENT_TO_KITCHEN
  READY
  PACKED
  DELIVERED_PAID
  CANCELLED
}

enum DispatcherShiftStatus {
  OPEN
  CLOSED
}

enum ClientType {
  CLIENT
  ORGANIZATION
}

model User {
  id                Int      @id @default(autoincrement())
  phone             String   @unique
  password          String
  role              String   @default("admin")
  passwordUpdatedAt DateTime?
  createdAt         DateTime @default(now())
  sessions          Session[]
  openedDispatcherShifts DispatcherShift[] @relation("DispatcherShiftOpenedBy")
  closedDispatcherShifts DispatcherShift[] @relation("DispatcherShiftClosedBy")
}

model Session {
  sessionId String    @id @default(uuid())
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId    Int
  createdAt DateTime  @default(now())
  expiresAt DateTime
  revokedAt DateTime?
  revokedReason String?
  userAgent String?
  ip        String?

  @@index([userId])
  @@index([expiresAt])
  @@map("sessions")
}

model AuthAttempt {
  attemptKey      String    @id
  count           Int       @default(0)
  windowStartedAt DateTime  @default(now())
  lockedUntil     DateTime?
  updatedAt       DateTime  @updatedAt

  @@map("auth_attempts")
}

model RolePermission {
  role       String
  permission String
  createdAt  DateTime @default(now())

  @@id([role, permission])
}

model AuditLog {
  id          Int      @id @default(autoincrement())
  actorUserId Int?
  action      String
  entityType  String
  entityId    String?
  before      Json?
  after       Json?
  createdAt   DateTime @default(now())
  ip          String?

  @@index([actorUserId])
  @@index([entityType, entityId])
  @@index([createdAt])
  @@map("audit_log")
}

model Client {
  id        Int      @id @default(autoincrement())
  name      String
  type      ClientType @default(CLIENT)
  email     String?
  phone     String   @unique
  birthDate DateTime?
  address   String?
  notes     String?
  loyaltyLevelOverride String?
  createdAt DateTime @default(now())
  orders    Order[]
}

model PhoneVerificationCode {
  id         Int       @id @default(autoincrement())
  phone      String
  purpose    String
  codeHash   String
  attempts   Int       @default(0)
  expiresAt  DateTime
  consumedAt DateTime?
  createdAt  DateTime  @default(now())

  @@index([phone, purpose, createdAt])
}

model Product {
  id          Int      @id @default(autoincrement())
  name        String
  sku         String?  @unique
  category    String?
  kitchenZone String?
  unit        String
  stockQuantity Float  @default(0)
  priceCents  Int
  description String?
  createdAt   DateTime @default(now())
  orderItems  OrderItem[]
  ingredients TechCardIngredient[]
  inventoryItems InventorySessionItem[]
  incomingItems IncomingActItem[]
  writeoffItems WriteoffActItem[]
  orderInventoryMovements OrderInventoryMovement[]
  packagingUsages OrderPackagingUsage[]
  catalogItemExcludedIngredients CatalogItemExcludedIngredient[]
  orderItemExcludedIngredients OrderItemExcludedIngredient[]
}

model Employee {
  id           Int      @id @default(autoincrement())
  name         String
  email        String?  @unique
  role         String
  phone        String?
  messenger    String?
  schedule     Json?    // График работы, например { "monday": 8, "tuesday": 8, ... }
  monthlyHours Int?     // Рассчитанные часы работы за месяц
  birthDate    DateTime?
  hireDate     DateTime?
  passwordUpdatedAt DateTime?
  createdAt    DateTime @default(now())
  orders       Order[]
  adjustments  EmployeeAdjustment[]
  inventorySessions InventorySession[]
  incomingActs IncomingAct[]
  writeoffActs WriteoffAct[]
}

enum EmployeeAdjustmentType {
  ADVANCE
  FINE
  DEBT
}

enum ManagementAccountingEntryType {
  INCOME
  EXPENSE
}

enum ManagementAccountingDayStatus {
  OPEN
  CLOSED
}

model EmployeeAdjustment {
  id         Int                     @id @default(autoincrement())
  employee   Employee                @relation(fields: [employeeId], references: [id])
  employeeId Int
  type       EmployeeAdjustmentType
  amountCents Int
  comment    String?
  createdAt  DateTime                @default(now())
}

model ManagementAccountingEntry {
  id              Int                           @id @default(autoincrement())
  businessDate    DateTime
  type            ManagementAccountingEntryType
  category        String
  amountCents     Int
  comment         String?
  createdByUserId Int?
  createdAt       DateTime                      @default(now())
  updatedAt       DateTime                      @updatedAt

  @@index([businessDate])
  @@index([businessDate, type])
}

model ManagementAccountingDay {
  id              Int                           @id @default(autoincrement())
  businessDate    DateTime                      @unique
  status          ManagementAccountingDayStatus
  openedByUserId  Int?
  openedAt        DateTime                      @default(now())
  closedByUserId  Int?
  closedAt        DateTime?
  snapshot         Json?
  createdAt       DateTime                      @default(now())
  updatedAt       DateTime                      @updatedAt

  @@index([status])
  @@index([businessDate, status])
}

model Order {
  id          Int         @id @default(autoincrement())
  status      OrderStatus @default(NEW)
  source      String      @default("ADMIN")
  isInternal  Boolean     @default(false)
  shift       DispatcherShift? @relation(fields: [shiftId], references: [id])
  shiftId     Int?
  client      Client?     @relation(fields: [clientId], references: [id], onDelete: SetNull)
  clientId    Int?
  clientNameSnapshot String
  clientTypeSnapshot ClientType
  customerPhoneSnapshot String?
  deliveryAddressSnapshot String?
  customerComment String?
  employee    Employee    @relation(fields: [employeeId], references: [id])
  employeeId  Int
  subtotalCents Int
  discountPercent Int      @default(0)
  totalCents  Int
  createdAt   DateTime    @default(now())
  items       OrderItem[]
  inventoryMovements OrderInventoryMovement[]
  packagingUsages OrderPackagingUsage[]

  @@index([shiftId])
  @@index([shiftId, status])
}

model DispatcherShift {
  id                       Int                   @id @default(autoincrement())
  number                   Int                   @unique
  businessDate             DateTime              @unique
  status                   DispatcherShiftStatus
  timeZone                 String
  openedAt                 DateTime
  closedAt                 DateTime?
  responsibleName          String
  closedByName             String?
  openedByUser             User                  @relation("DispatcherShiftOpenedBy", fields: [openedByUserId], references: [id])
  openedByUserId           Int
  closedByUser             User?                 @relation("DispatcherShiftClosedBy", fields: [closedByUserId], references: [id])
  closedByUserId           Int?
  checksCountSnapshot      Int?
  revenueCentsSnapshot     Int?
  cancelledOrdersSnapshot  Int?
  totalOrdersSnapshot      Int?
  createdAt                DateTime              @default(now())
  updatedAt                DateTime              @updatedAt
  orders                   Order[]

  @@index([status])
  @@index([businessDate])
}

model OrderInventoryMovement {
  id                  Int      @id @default(autoincrement())
  order               Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  orderId             Int
  product             Product  @relation(fields: [productId], references: [id])
  productId           Int
  productName         String
  productUnit         String
  quantity            Float
  movementType        String
  orderStatus         OrderStatus
  reason              String
  actorUserId         Int?
  stockQuantityBefore Float
  stockQuantityAfter  Float
  createdAt           DateTime @default(now())

  @@unique([orderId, productId, movementType])
  @@index([orderId, createdAt])
  @@index([productId, createdAt])
}

model OrderItem {
  id              Int     @id @default(autoincrement())
  order           Order   @relation(fields: [orderId], references: [id])
  orderId         Int
  product         Product? @relation(fields: [productId], references: [id])
  productId       Int?
  catalogItem     CatalogItem? @relation(fields: [catalogItemId], references: [id])
  catalogItemId   Int?
  catalogItemVariant CatalogItemVariant? @relation(fields: [catalogItemVariantId], references: [id])
  catalogItemVariantId Int?
  itemName        String
  quantity        Int
  unitPriceCents  Int
  totalPriceCents Int
  choices         OrderItemChoice[]
  excludedIngredients OrderItemExcludedIngredient[]
  packagingUsages OrderPackagingUsage[]
}

model OrderItemExcludedIngredient {
  id                              Int                           @id @default(autoincrement())
  orderItem                       OrderItem                     @relation(fields: [orderItemId], references: [id], onDelete: Cascade)
  orderItemId                     Int
  catalogItemExcludedIngredient   CatalogItemExcludedIngredient? @relation(fields: [catalogItemExcludedIngredientId], references: [id], onDelete: SetNull)
  catalogItemExcludedIngredientId Int?
  product                         Product                       @relation(fields: [productId], references: [id])
  productId                       Int
  label                           String

  @@index([catalogItemExcludedIngredientId])
  @@index([productId])
}

model OrderItemChoice {
  id                         Int               @id @default(autoincrement())
  orderItem                  OrderItem         @relation(fields: [orderItemId], references: [id], onDelete: Cascade)
  orderItemId                Int
  choiceSlot                 TechCardChoiceSlot @relation(fields: [choiceSlotId], references: [id])
  choiceSlotId               Int
  selectedTechnologicalCard  TechnologicalCard @relation("OrderItemSelectedTechCardChoices", fields: [selectedTechnologicalCardId], references: [id])
  selectedTechnologicalCardId Int
  position                   Int      @default(0)
  quantity                   Float

  @@unique([orderItemId, choiceSlotId, position])
  @@index([choiceSlotId])
  @@index([selectedTechnologicalCardId])
}

model OrderPackagingUsage {
  id                  Int      @id @default(autoincrement())
  order               Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  orderId             Int
  orderItem           OrderItem @relation(fields: [orderItemId], references: [id], onDelete: Cascade)
  orderItemId         Int
  unitIndex           Int
  packageProduct      Product  @relation(fields: [packageProductId], references: [id])
  packageProductId    Int
  packageProductName  String
  kitchenZone         String
  actorUserId         Int?
  stockQuantityBefore Float
  stockQuantityAfter  Float
  createdAt           DateTime @default(now())

  @@unique([orderItemId, unitIndex, kitchenZone])
  @@index([orderId, createdAt])
  @@index([packageProductId, createdAt])
}

model TechnologicalCard {
  id             Int                  @id @default(autoincrement())
  name           String
  category       String
  pizzaSize      String?
  rollSize       String?
  outputQuantity Float
  outputUnit     String
  description    String?
  createdAt      DateTime             @default(now())
  ingredients    TechCardIngredient[]
  components     TechCardComponent[]   @relation("TechCardComponents")
  usedInCards     TechCardComponent[]   @relation("TechCardComponentSource")
  choiceSlots    TechCardChoiceSlot[]
  selectedInOrderChoices OrderItemChoice[] @relation("OrderItemSelectedTechCardChoices")
  catalogItems   CatalogItem[]
  catalogItemVariants CatalogItemVariant[]
}

model TechCardIngredient {
  id                  Int               @id @default(autoincrement())
  technologicalCard   TechnologicalCard @relation(fields: [technologicalCardId], references: [id])
  technologicalCardId Int
  product             Product           @relation(fields: [productId], references: [id])
  productId           Int
  quantity            Float
  unit                String
}

model TechCardComponent {
  id                         Int               @id @default(autoincrement())
  technologicalCard          TechnologicalCard @relation("TechCardComponents", fields: [technologicalCardId], references: [id])
  technologicalCardId        Int
  componentTechnologicalCard TechnologicalCard @relation("TechCardComponentSource", fields: [componentTechnologicalCardId], references: [id])
  componentTechnologicalCardId Int
  quantity                   Float

  @@unique([technologicalCardId, componentTechnologicalCardId])
  @@index([componentTechnologicalCardId])
}

model TechCardChoiceSlot {
  id                  Int               @id @default(autoincrement())
  technologicalCard   TechnologicalCard @relation(fields: [technologicalCardId], references: [id], onDelete: Cascade)
  technologicalCardId Int
  name                String
  category            String
  allowedPizzaSizes   String[]          @default([])
  quantity            Float
  orderItemChoices    OrderItemChoice[]

  @@index([technologicalCardId])
}

model CatalogItem {
  id                  Int               @id @default(autoincrement())
  name                String
  slug                String            @unique
  category            String?
  description         String?
  imageUrl            String?
  kitchenZone         String?
  kitchenZones        String[]          @default([])
  priceCents          Int
  isPublished         Boolean           @default(false)
  displayOrder        Int               @default(0)
  createdAt           DateTime          @default(now())
  technologicalCard   TechnologicalCard @relation(fields: [technologicalCardId], references: [id])
  technologicalCardId Int
  variants            CatalogItemVariant[]
  excludedIngredients CatalogItemExcludedIngredient[]
  orderItems          OrderItem[]
}

model CatalogItemExcludedIngredient {
  id            Int         @id @default(autoincrement())
  catalogItem   CatalogItem @relation(fields: [catalogItemId], references: [id], onDelete: Cascade)
  catalogItemId Int
  product       Product     @relation(fields: [productId], references: [id])
  productId     Int
  label         String
  displayOrder  Int         @default(0)
  orderItemExcludedIngredients OrderItemExcludedIngredient[]

  @@unique([catalogItemId, productId])
  @@index([productId])
}

model CatalogItemVariant {
  id                  Int               @id @default(autoincrement())
  catalogItem         CatalogItem       @relation(fields: [catalogItemId], references: [id], onDelete: Cascade)
  catalogItemId       Int
  technologicalCard   TechnologicalCard @relation(fields: [technologicalCardId], references: [id])
  technologicalCardId Int
  label               String
  priceCents          Int
  isDefault           Boolean           @default(false)
  displayOrder        Int               @default(0)
  orderItems          OrderItem[]

  @@unique([catalogItemId, technologicalCardId])
  @@index([technologicalCardId])
}

model InventorySession {
  id                    Int                    @id @default(autoincrement())
  responsibleEmployee   Employee               @relation(fields: [responsibleEmployeeId], references: [id])
  responsibleEmployeeId Int
  notes                 String?
  createdAt             DateTime               @default(now())
  closedAt              DateTime?
  items                 InventorySessionItem[]
}

model InventorySessionItem {
  id                 Int              @id @default(autoincrement())
  inventorySession   InventorySession @relation(fields: [inventorySessionId], references: [id])
  inventorySessionId Int
  product            Product?         @relation(fields: [productId], references: [id], onDelete: SetNull)
  productId          Int?
  productName        String
  productCategory    String?
  productUnit        String
  stockQuantity      Float
  actualQuantity     Float?
}

model IncomingAct {
  id                    Int               @id @default(autoincrement())
  responsibleEmployee   Employee          @relation(fields: [responsibleEmployeeId], references: [id])
  responsibleEmployeeId Int
  supplierName          String?
  notes                 String?
  createdAt             DateTime          @default(now())
  completedAt           DateTime?
  items                 IncomingActItem[]
}

model IncomingActItem {
  id                  Int         @id @default(autoincrement())
  incomingAct         IncomingAct @relation(fields: [incomingActId], references: [id])
  incomingActId       Int
  product             Product     @relation(fields: [productId], references: [id])
  productId           Int
  productName         String
  productCategory     String?
  productUnit         String
  quantity            Float
  priceCents          Int
  stockQuantityBefore Float?
  stockQuantityAfter  Float?
}

model WriteoffAct {
  id                    Int               @id @default(autoincrement())
  responsibleEmployee   Employee          @relation(fields: [responsibleEmployeeId], references: [id])
  responsibleEmployeeId Int
  reason                String
  notes                 String?
  createdAt             DateTime          @default(now())
  completedAt           DateTime?
  items                 WriteoffActItem[]
}

model WriteoffActItem {
  id                  Int         @id @default(autoincrement())
  writeoffAct         WriteoffAct @relation(fields: [writeoffActId], references: [id])
  writeoffActId       Int
  product             Product     @relation(fields: [productId], references: [id])
  productId           Int
  productName         String
  productCategory     String?
  productUnit         String
  quantity            Float
  priceCents          Int
  stockQuantityBefore Float?
  stockQuantityAfter  Float?
}
