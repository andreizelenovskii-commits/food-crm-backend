PORT=4000
HOST=127.0.0.1
DATABASE_URL=postgresql://food_crm_user:change-me@localhost:5432/food_crm
SESSION_SECRET=change-me
BACKEND_SESSION_SECRET=
BACKEND_SESSION_COOKIE_NAME=food_crm_api_session
BACKEND_SESSION_COOKIE_DOMAIN=.crmandromeda.ru
BACKEND_SESSION_TTL_DAYS=30
BACKEND_CORS_ORIGIN=https://crm.crmandromeda.ru,http://localhost:3000,http://127.0.0.1:3000

# Public site SMS auth via SMS Aero.
# In production keep SMSAERO_ENABLED=true and set real account values.
# For local development set SMSAERO_ENABLED=false to print codes in backend logs.
SMSAERO_ENABLED=true
SMSAERO_EMAIL=
SMSAERO_API_KEY=
SMSAERO_SIGN=SMS Aero
